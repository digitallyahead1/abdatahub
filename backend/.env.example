# Backend Configuration
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://abdatahub_user:Abdatahub@@localhost:5432/ab_data_hub
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=abdatahub_user
DATABASE_PASSWORD=Abdatahub@
DATABASE_NAME=ab_data_hub

# Redis
REDIS_URL=redis://:abdatahub_redis_password@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=abdatahub_redis_password

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# OTP
OTP_EXPIRATION=5m
OTP_MAX_ATTEMPTS=5

# Payment Gateways
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key
FLUTTERWAVE_PUBLIC_KEY=pk_test_your_flutterwave_key
FLUTTERWAVE_SECRET_KEY=sk_test_your_flutterwave_key

# Moniepoint
MONIEPOINT_API_KEY=your_moniepoint_api_key
MONIEPOINT_BASE_URL=https://api.moniepoint.com

# SMS Service
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Email Service
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_email_password
MAIL_FROM=noreply@abdatahub.com

# Logging
LOG_LEVEL=debug

# API Configuration
API_VERSION=v1
API_PREFIX=api

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SMEPlug Configuration
SMEPLUG_SECRET_KEY=your_smeplug_api_secret_key
SMEPLUG_BASE_URL=https://smeplug.ng/api/v1

# Termii Email Configuration
TERMII_BASE_URL=https://v3.api.termii.com
TERMII_API_KEY=your_termii_api_key
TERMII_TEMPLATE_ID=your_termii_template_id
TERMII_CONFIG_ID=your_termii_config_id

# Monnify Integration
MONNIFY_API_KEY=your_monnify_api_key
MONNIFY_SECRET_KEY=your_monnify_secret_key
MONNIFY_CONTRACT_CODE=your_monnify_contract_code
MONNIFY_BASE_URL=https://sandbox.monnify.com

# Gafiapay Integration
GAFIAPAY_API_KEY=your_gafiapay_api_key
GAFIAPAY_SECRET_KEY=your_gafiapay_secret_key
GAFIAPAY_BASE_URL=https://api.gafiapay.com/api/v1/external
GAFIAPAY_EXPIRY_DURATION=86400

# AMZAET Configuration
AMZAET_TOKEN=your_amzaet_token



